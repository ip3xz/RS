# =========================================================
# PIECEWISE LINEAR CONTRAST STRETCHING
# =========================================================

# Define transformation function
def piecewise_linear_transform(image, r1, s1, r2, s2):

    stretched_image = np.zeros_like(image)

    # Segment 1
    mask1 = image < r1
    stretched_image[mask1] = (s1 / r1) * image[mask1]

    # Segment 2
    mask2 = (image >= r1) & (image < r2)
    stretched_image[mask2] = (
        ((s2 - s1) / (r2 - r1)) *
        (image[mask2] - r1)
    ) + s1

    # Segment 3
    mask3 = image >= r2
    stretched_image[mask3] = (
        ((1 - s2) / (1 - r2)) *
        (image[mask3] - r2)
    ) + s2

    return stretched_image

# Breakpoints
r1, s1 = 0.2, 0.1
r2, s2 = 0.7, 0.9

# Normalize image to 0-1
normalized_img = img.astype(float) / 255.0

# Apply transformation
piecewise_stretched = piecewise_linear_transform(
    normalized_img,
    r1, s1,
    r2, s2
)

# Display Results
plt.figure(figsize=(12,6))

plt.subplot(1,2,1)
plt.title("Original Normalized Band")
plt.imshow(normalized_img, cmap='gray')
plt.colorbar()

plt.subplot(1,2,2)
plt.title("Piece-wise Contrast Stretched Image")
plt.imshow(piecewise_stretched, cmap='gray')
plt.colorbar()

plt.tight_layout()
plt.show()

