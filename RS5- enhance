# PART B : RADIOMETRIC / ATMOSPHERIC CORRECTION
# =========================================================

# Extract parameters from MTL file
def get_mtl_values(mtl_file, band):

    with open(mtl_file, "r") as f:
        text = f.read()

    ML = float(re.search(
        rf'RADIANCE_MULT_BAND_{band}\s=\s([0-9E\-\.+]+)',
        text).group(1))

    AL = float(re.search(
        rf'RADIANCE_ADD_BAND_{band}\s=\s([0-9E\-\.+]+)',
        text).group(1))

    Mp = float(re.search(
        rf'REFLECTANCE_MULT_BAND_{band}\s=\s([0-9E\-\.+]+)',
        text).group(1))

    Ap = float(re.search(
        rf'REFLECTANCE_ADD_BAND_{band}\s=\s([0-9E\-\.+]+)',
        text).group(1))

    sun_elev = float(re.search(
        r'SUN_ELEVATION\s=\s([0-9E\-\.+]+)',
        text).group(1))

    earth_sun_dist = float(re.search(
        r'EARTH_SUN_DISTANCE\s=\s([0-9E\-\.+]+)',
        text).group(1))

    return ML, AL, Mp, Ap, sun_elev, earth_sun_dist

# ESUN values
ESUN = {
    1: 1970,
    2: 1842,
    3: 1547,
    4: 1044,
    5: 225.7
}

# Files
mtl_file = "/content/drive/MyDrive/FinalYear-Sem-8_Lab/RS/MTL.txt"

band_file = "/content/drive/MyDrive/FinalYear-Sem-8_Lab/RS/B5.TIF"

band = 4

# Read DN image
with rasterio.open(band_file) as src:

    DN = src.read(1).astype(np.float32)

    nodata = src.nodata

    if nodata is not None:
        DN = np.where(DN == nodata, np.nan, DN)

print("DN stats:", np.nanmin(DN), np.nanmax(DN))

# Extract MTL values
ML, AL, Mp, Ap, sun_elev, earth_sun_dist = get_mtl_values(
    mtl_file,
    band
)

# TOA Radiance
radiance = ML * DN + AL

# Reflectance without correction
reflectance_uncorrected = Mp * DN + Ap

# Reflectance with sun angle correction
reflectance_angle = (
    reflectance_uncorrected /
    np.sin(np.deg2rad(sun_elev))
)

# TOA Reflectance using ESUN
theta_sz = 90.0 - sun_elev

reflectance_esun = (
    (np.pi * radiance * (earth_sun_dist**2)) /
    (ESUN[band] * np.cos(np.deg2rad(theta_sz)))
)

# Pick valid pixel
valid_pixels = np.argwhere(~np.isnan(DN))

row, col = valid_pixels[0]

print("Valid pixel chosen at:", row, col)
print("DN =", DN[row, col])
print("Radiance =", radiance[row, col])
print("Reflectance (uncorrected) =", reflectance_uncorrected[row, col])
print("Reflectance (angle corrected) =", reflectance_angle[row, col])
print("TOA Reflectance (ESUN method) =", reflectance_esun[row, col])

