image_path = "/content/drive/MyDrive/FinalYear-Sem-8_Lab/RS/Capture.PNG"

img = cv2.imread(image_path, cv2.IMREAD_GRAYSCALE)

# Normalize Image
band_norm = img.astype(float)

# Gaussian Smoothing
gaussian_smooth = cv2.GaussianBlur(band_norm, (5,5), 0)

# Mean Smoothing
mean_smooth = cv2.blur(band_norm, (5,5))

# Sharpening
kernel = np.array(([0,-1,0],
                   [-1,6,-1],
                   [0,-1,0]))

sharpened = cv2.filter2D(band_norm, -1, kernel)

# Sobel Directions
sobel_x = cv2.Sobel(band_norm, cv2.CV_64F, 1, 0, ksize=3)
sobel_y = cv2.Sobel(band_norm, cv2.CV_64F, 0, 1, ksize=3)

sobel_xy = np.sqrt(sobel_x**2 + sobel_y**2)

# Canny Edge Detection
edges = cv2.Canny(img, 100, 200)

